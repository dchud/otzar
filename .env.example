# Django

# required; generate with:
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# set to false in production
DEBUG=true

ALLOWED_HOSTS=localhost,127.0.0.1

# set to production URL(s) when deployed, e.g. https://otzar.fly.dev
# leave empty for local dev
CSRF_TRUSTED_ORIGINS=

# root for persistent data (db, media, cache live under this)
# on Fly.io: /data (persistent volume); locally: defaults to project root
# e.g. database at DATA_DIR/db.sqlite3, images at DATA_DIR/media/
DATA_DIR=

# Claude Vision OCR

# required for title page scanning
ANTHROPIC_API_KEY=

# Haiku: ~$0.003/image ($3 per 1,000 scans); Sonnet: ~$0.02/image ($20 per 1,000 scans)
# Sonnet is more accurate for Hebrew decorative fonts (11/12 vs 5/12 in testing)
CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6

# S3 backups (optional; only needed if using Litestream for continuous SQLite
# backup to S3. Fly.io provides daily volume snapshots without this.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1

# SRU catalog endpoints (defaults are the public endpoints; leave empty to use defaults)
# SRU_NLI_URL=https://nli.alma.exlibrisgroup.com/view/sru/972NNL_INST
# SRU_LC_URL=http://lx2.loc.gov:210/LCDB
# SRU_DNB_URL=https://services.dnb.de/sru/dnb
# SRU_VIAF_URL=https://viaf.org/viaf/search

# seconds between requests to external catalogs
SRU_REQUEST_DELAY=3

# Open Library Covers API (optional override)
# COVER_API_URL=https://covers.openlibrary.org/b

# Site settings

# prefix for generated record identifiers
RECORD_ID_PREFIX=otzar-

# optional; if set, public pages require this password
SITE_PASSWORD=
